# =============================================================================
# TrustShield Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# =============================================================================
# TrustShield Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=TrustShield
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false                      # true to enable debug mode

# -----------------------------------------------------------------------------
# JWT Authentication (REQUIRED — no default, must be set)
# -----------------------------------------------------------------------------
JWT_SECRET=                      # Minimum 32 chars. Generate: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# API / CORS
# -----------------------------------------------------------------------------
API_KEY=                         # API key for authenticated requests (leave empty to disable auth)
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list of allowed CORS origins

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/trustshield

# -----------------------------------------------------------------------------
# Redis (used by Celery and caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Neo4j (graph database for fraud relationship mapping)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# -----------------------------------------------------------------------------
# Kafka (event streaming)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# ML Model
# -----------------------------------------------------------------------------
MURIL_MODEL_PATH=trustshield/backend/ml/artifacts/muril_scam_classifier/model.onnx

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# -----------------------------------------------------------------------------
# Rate Limits
# -----------------------------------------------------------------------------
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_ANALYZE=100/minute
RATE_LIMIT_WEBHOOK=1000/minute
RATE_LIMIT_SCAN=60/minute

# -----------------------------------------------------------------------------
# Billing (Stripe) — disabled in development
# -----------------------------------------------------------------------------
BILLING_ENABLED=false              # Set true in production
STRIPE_SECRET_KEY=                 # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=             # whsec_...
STRIPE_PRICE_ID_FREE=              # price_... for Free tier
STRIPE_PRICE_ID_PRO=               # price_... for Pro tier
STRIPE_PRICE_ID_BANK=              # price_... for Bank tier
STRIPE_PRICE_ID_ENTERPRISE=        # price_... for Enterprise tier

# -----------------------------------------------------------------------------
# PII Encryption — disabled in development (stores plaintext)
# -----------------------------------------------------------------------------
PII_ENCRYPTION_KEY=                # Base64-encoded 32-byte key for AES-256-GCM
