{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{route}} {{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Latency P95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "DB Pool Utilization",
      "type": "gauge",
      "targets": [
        {
          "expr": "db_pool_utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.8, "color": "yellow" }, { "value": 0.95, "color": "red" }] } }
      }
    },
    {
      "title": "Active Celery Workers",
      "type": "stat",
      "targets": [
        {
          "expr": "celery_workers_active",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["trustshield"],
  "templating": {
    "list": [
      { "name": "environment", "type": "custom", "query": "staging,prod" },
      { "name": "instance", "type": "query", "query": "label_values(http_requests_total, instance)" }
    ]
  },
  "title": "TrustShield Overview",
  "uid": "trustshield-overview"
}
