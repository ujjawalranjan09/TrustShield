{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Availability SLO (30d)",
      "type": "gauge",
      "targets": [
        {
          "expr": "job:http_availability:ratio_rate30m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0.9, "max": 1, "thresholds": { "steps": [{ "value": 0.999, "color": "green" }, { "value": 0.99, "color": "yellow" }, { "value": 0, "color": "red" }] } }
      }
    },
    {
      "title": "Analyze P95 Latency",
      "type": "gauge",
      "targets": [
        {
          "expr": "job:analyze_p95:rate5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.3, "color": "yellow" }, { "value": 0.5, "color": "red" }] } }
      }
    },
    {
      "title": "Availability Burn Rate (6h)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - job:http_availability:ratio_rate30m) / (1 - 0.999) * 14.4",
          "legendFormat": "burn rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 14.4, "color": "red" }] } }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["trustshield", "slo"],
  "title": "TrustShield SLOs",
  "uid": "trustshield-slo"
}
